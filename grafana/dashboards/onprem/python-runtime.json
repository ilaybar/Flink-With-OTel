{
  "annotations": { "list": [] },
  "description": "Python runtime dashboard for services instrumented with opentelemetry-instrumentation-system-metrics (via opentelemetry-instrument or SystemMetricsInstrumentor). Uses the current (non-deprecated) process.* / cpython.* metric names; older package versions emit process_runtime_cpython_* instead — check your /metrics endpoint if panels are empty.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Memory & CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Resident memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "process_memory_usage_bytes{job=~\"$job\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Virtual memory",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "process_memory_virtual_bytes{job=~\"$job\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Process CPU utilization",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "process_cpu_utilization_ratio{job=~\"$job\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" } ]
    },
    {
      "type": "timeseries",
      "title": "CPU time rate (user / system)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (pod, type) (rate(process_cpu_time_seconds_total{job=~\"$job\", pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{pod}} {{type}}" } ]
    },
    {
      "type": "row",
      "title": "GC, threads & context switches",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "GC collections /s (by generation)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (pod, generation) (rate(cpython_gc_collections_total{job=~\"$job\", pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{pod}} gen {{generation}}" } ]
    },
    {
      "type": "timeseries",
      "title": "GC collected objects /s",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (pod) (rate(cpython_gc_collected_objects_total{job=~\"$job\", pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{pod}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Threads",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 7,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "process_thread_count{job=~\"$job\", pod=~\"$pod\"}", "legendFormat": "{{pod}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Context switches /s (voluntary / involuntary)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 8,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (pod, type) (rate(process_context_switches_total{job=~\"$job\", pod=~\"$pod\"}[$__rate_interval]))", "legendFormat": "{{pod}} {{type}}" } ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["otel", "python", "onprem"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(process_memory_usage_bytes, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service (job)",
        "multi": true,
        "name": "job",
        "options": [],
        "query": { "query": "label_values(process_memory_usage_bytes, job)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(process_memory_usage_bytes{job=~\"$job\"}, pod)",
        "hide": 0,
        "includeAll": true,
        "label": "Pod",
        "multi": true,
        "name": "pod",
        "options": [],
        "query": { "query": "label_values(process_memory_usage_bytes{job=~\"$job\"}, pod)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Python Runtime (OpenTelemetry)",
  "uid": "otel-python-runtime",
  "version": 1,
  "weekStart": ""
}
