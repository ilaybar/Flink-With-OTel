{
  "annotations": { "list": [] },
  "description": "Kafka producer & consumer client metrics for all JVM services instrumented with the OpenTelemetry Java agent (kafka-clients instrumentation). Variables chain top-down: job -> topic -> client/partition. Note: kafka client metrics have no consumer-group label; 'client' is the Kafka client.id. If a panel is empty, verify exact metric names at <pod>:9464/metrics (exporter versions may append unit suffixes).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Producer",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Records sent /s (by topic)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (topic) (rate(kafka_producer_record_send_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "{{topic}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Bytes sent /s (by topic)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (topic) (rate(kafka_producer_byte_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "{{topic}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Record errors & retries /s (by topic)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "errors.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byRegexp", "options": "retries.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum by (topic) (rate(kafka_producer_record_error_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "errors {{topic}}" },
        { "refId": "B", "expr": "sum by (topic) (rate(kafka_producer_record_retry_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "retries {{topic}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Producer request latency avg (per broker node)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_producer_request_latency_avg{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "{{client_id}} node {{node_id}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Requests in flight",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "id": 5,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_producer_requests_in_flight{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "{{client_id}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Batch size avg",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "id": 6,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_producer_batch_size_avg{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "{{client_id}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Producer buffer available",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "id": 7,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_producer_buffer_available_bytes{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "{{client_id}}" } ]
    },
    {
      "type": "row",
      "title": "Consumer",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Records consumed /s (by topic)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 8,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (topic) (rate(kafka_consumer_records_consumed_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "{{topic}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Bytes consumed /s (by topic)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 9,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "sum by (topic) (rate(kafka_consumer_bytes_consumed_total{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\"}[$__rate_interval]))", "legendFormat": "{{topic}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Consumer lag (records, by topic/partition)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 10,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_consumer_records_lag{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\", partition=~\"$partition\"}", "legendFormat": "{{topic}}-{{partition}} ({{client_id}})" } ]
    },
    {
      "type": "timeseries",
      "title": "Consumer lag max",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
