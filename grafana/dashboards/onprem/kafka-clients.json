      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_consumer_records_lag_max{job=~\"$job\", client_id=~\"$client\", topic=~\"$topic\", partition=~\"$partition\"}", "legendFormat": "{{topic}}-{{partition}} ({{client_id}})" } ]
    },
    {
      "type": "timeseries",
      "title": "Fetch latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 12,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "kafka_consumer_fetch_latency_avg{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "avg {{client_id}}" },
        { "refId": "B", "expr": "kafka_consumer_fetch_latency_max{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "max {{client_id}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Commit latency avg",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 13,
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "expr": "kafka_consumer_commit_latency_avg{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "{{client_id}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Rebalances per hour",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "id": 14,
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "failed.*" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "kafka_consumer_rebalance_rate_per_hour{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "rebalances {{client_id}}" },
        { "refId": "B", "expr": "kafka_consumer_failed_rebalance_rate_per_hour{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "failed {{client_id}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Assigned partitions & poll staleness",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "id": 15,
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "drawStyle": "line", "spanNulls": true } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "last poll.*" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "kafka_consumer_assigned_partitions{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "partitions {{client_id}}" },
        { "refId": "B", "expr": "kafka_consumer_last_poll_seconds_ago{job=~\"$job\", client_id=~\"$client\"}", "legendFormat": "last poll {{client_id}}" }
      ]
    }
  ],
